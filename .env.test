# ─── Playwright E2E Test Environment ───────────────────────────────
# Copy this file to .env.test.local and fill in real values.

# Base URL for tests (leave empty to auto-start dev server)
# E2E_BASE_URL=http://localhost:3000

# Test user credentials (non-admin org_user role)
E2E_USER_EMAIL=james.lee@acme.test
E2E_USER_PASSWORD=password123

# Admin test user credentials (isAdmin: true, for admin.spec.ts)
E2E_ADMIN_EMAIL=admin@acme.test
E2E_ADMIN_PASSWORD=password123

# Database (needed for dev server)
# DATABASE_URL=postgresql://user:password@localhost:5432/peg_test

# NextAuth
# AUTH_SECRET=test-secret-do-not-use-in-production
